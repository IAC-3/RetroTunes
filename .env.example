# Variabili d'Ambiente - RetroTunes

## Development
TAURI_ENV=development
RUST_LOG=debug
RUST_BACKTRACE=1

## Build
TAURI_PRIVATE_KEY=               # Da riempire per distribuzione
TAURI_KEY_PASSWORD=              # Da riempire per distribuzione

## Feature Flags (Rust)
# FEATURES=--all-features        # Compila con tutte le features

## Platform Specifici
# Per macOS ARM64:
# RUSTFLAGS=-C target-cpu=native
# CARGO_CFG_TARGET_ARCH=aarch64
